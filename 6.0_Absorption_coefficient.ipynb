   "source": [
    "# Abersorption coefficient\n",
    "\n",
    "$$ I(\\omega) = \\sqrt{2}[\\sqrt{\\varepsilon_R^2(\\omega)+\\varepsilon_I^2(\\omega)}-\\varepsilon_R(\\omega)] $$\n",
    "\n",
    "where:\n",
    "\n",
    "$\\varepsilon_R$ is real part dielectric function;\n",
    "\n",
    "$\\varepsilon_I$ is real part dielectric function;\n"
   ]
